{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# LNP Hyperparameter Tuning Framework - Example Usage\n",
    "\n",
    "This notebook demonstrates how to use the LNP hyperparameter tuning framework for training and evaluating models.\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Setup and Imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import yaml\n",
    "\n",
    "# Add src to path\n",
    "sys.path.append('../src')\n",
    "\n",
    "from data.data_loader import LNPDataLoader\n",
    "from training.trainer import LNPTrainer\n",
    "from training.hyperparameter_tuner import ComprehensiveHyperparameterTuner\n",
    "from evaluation.evaluator import LNPEvaluator\n",
    "from utils.model_utils import setup_device, load_best_model\n",
    "\n",
    "%matplotlib inline\n",
    "plt.style.use('seaborn-v0_8')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load configuration\n",
    "with open('../config/config.yaml', 'r') as f:\n",
    "    config = yaml.safe_load(f)\n",
    "\n",
    "print(\"Configuration loaded:\")\n",
    "print(f\"Model: {config['model']}\")\n",
    "print(f\"Training: {config['training']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Load and Prepare Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Setup device\n",
    "device = setup_device()\n",
    "\n",
    "# Load data\n",
    "data_loader = LNPDataLoader()\n",
    "\n",
    "# Replace with your actual data path\n",
    "data_path = '../data/lnp_data.json'  # Update this path\n",
    "# synthetic_path = '../data/synthetic_data.json'  # Optional\n",
    "\n",
    "data_config = data_loader.load_and_prepare(\n",
    "    data_path,\n",
    "    synthetic_data=None,  # Add synthetic_path if available\n",
    "    config=config['data'],\n",
    "    device=device\n",
    ")\n",
    "\n",
    "print(f\"Data loaded:\")\n",
    "print(f\"  Train samples: {len(data_config['train_data']['targets'])}\")\n",
    "print(f\"  Validation samples: {len(data_config['val_data']['targets'])}\")\n",
    "print(f\"  Molecular feature dim: {data_config['molecular_feature_dim']}\")\n",
    "print(f\"  Number of components: {data_config['n_components']}\")\n",
    "print(f\"  Property features: {data_config['property_dim']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Single Model Training Example"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create output directory\n",
    "output_dir = Path('../outputs/example_training')\n",
    "output_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Create trainer\n",
    "trainer = LNPTrainer(config, device)\n",
    "\n",
    "# Train model\n",
    "print(\"Starting training...\")\n",
    "results = trainer.train(data_config, output_dir)\n",
    "\n",
    "# Print results\n",
    "trainer.print_training_summary(results)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Visualize Training Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot training curves\n",
    "fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(15, 10))\n",
    "\n",
    "# Training loss\n",
    "ax1.plot(results['train_losses'], alpha=0.7, label='Training Loss')\n",
    "ax1.set_xlabel('Epoch')\n",
    "ax1.set_ylabel('Loss')\n",
    "ax1.set_title('Training Loss')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Validation loss\n",
    "val_epochs = list(range(0, len(results['val_losses']) * 5, 5))\n",
    "ax2.plot(val_epochs, results['val_losses'], color='orange', label='Validation Loss')\n",
    "ax2.set_xlabel('Epoch')\n",
    "ax2.set_ylabel('Loss')\n",
    "ax2.set_title('Validation Loss')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# Validation R²\n",
    "ax3.plot(val_epochs, results['val_r2_scores'], color='green', label='Validation R²')\n",
    "ax3.axhline(y=0.5, color='r', linestyle='--', alpha=0.7, label='R² = 0.5')\n",
    "ax3.set_xlabel('Epoch')\n",
    "ax3.set_ylabel('R² Score')\n",
    "ax3.set_title('Validation R² Score')\n",
    "ax3.legend()\n",
    "ax3.grid(True, alpha=0.3)\n",
    "\n",
    "# Training summary\n",
    "ax4.text(0.1, 0.8, f\"Best R²: {results['best_val_r2']:.4f}\", fontsize=14, fontweight='bold')\n",
    "ax4.text(0.1, 0.7, f\"Training Time: {results['training_time']/60:.1f} min\", fontsize=12)\n",
    "ax4.text(0.1, 0.6, f\"Final Epoch: {results['final_epoch']}\", fontsize=12)\n",
    "ax4.text(0.1, 0.5, f\"Model Path: {Path(results['best_model_path']).name}\", fontsize=10)\n",
    "ax4.set_xlim(0, 1)\n",
    "ax4.set_ylim(0, 1)\n",
    "ax4.set_title('Training Summary')\n",
    "ax4.axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Hyperparameter Search Example"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Modify config for smaller hyperparameter search (for demo)\n",
    "demo_config = config.copy()\n",
    "demo_config['hyperparameter_search']['max_trials'] = 5  # Small number for demo\n",
    "\n",
    "# Reduced search space for demo\n",
    "demo_config['hyperparameter_search']['search_space'] = {\n",
    "    'learning_rate': [1e-4, 1e-3, 3e-3],\n",
    "    'weight_decay': [0, 1e-5, 1e-4],\n",
    "    'dropout_rate': [0.1, 0.2],\n",
    "    'batch_size': [32],\n",
    "    'hidden_dims': [[128, 64], [256, 128]],\n",
    "    'num_heads': [4],\n",
    "    'early_stopping_patience': [30],\n",
    "    'scheduler_type': ['cosine', 'plateau'],\n",
    "    'loss_weights': [(1.0, 0.0, 0.0), (0.6, 0.3, 0.1)]\n",
    "}\n",
    "\n",
    "print(\"Starting hyperparameter search (demo with 5 trials)...\")\n",
    "\n",
    "# Create output directory\n",
    "hyperparam_output_dir = Path('../outputs/example_hyperparam_search')\n",
    "hyperparam_output_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Create tuner\n",
    "tuner = ComprehensiveHyperparameterTuner(data_config, demo_config['hyperparameter_search'])\n",
    "\n",
    "# Run search\n",
    "analysis = tuner.run_comprehensive_search(hyperparam_output_dir)\n",
    "\n",
    "print(f\"\\nHyperparameter search completed!\")\n",
    "print(f\"Best R²: {analysis['best_r2']:.4f}\")\n",
    "print(f\"Average R²: {analysis['avg_r2']:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Model Evaluation Example"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Use the best model from training or hyperparameter search\n",
    "best_model_path = results['best_model_path']  # From single training\n",
    "# Or use: best_model_path = hyperparam_output_dir / 'BEST_OVERALL_MODEL.pth'  # From hyperparameter search\n",
    "\n",
    "print(f\"Evaluating model: {best_model_path}\")\n",
    "\n",
    "# Create evaluator\n",
    "evaluator = LNPEvaluator(str(best_model_path), config['evaluation'])\n",
    "\n",
    "# Create evaluation output directory\n",
    "eval_output_dir = Path('../outputs/example_evaluation')\n",
    "eval_output_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Run comprehensive evaluation\n",
    "eval_results = evaluator.comprehensive_evaluation(\n",
    "    data_config,\n",
    "    eval_output_dir,\n",
    "    generate_plots=True\n",
    ")\n",
    "\n",
    "# Print evaluation summary\n",
    "evaluator.print_evaluation_summary(eval_results)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Making Predictions with Trained Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load the trained model\n",
    "model, checkpoint = load_best_model(str(best_model_path), device)\n",
    "\n",
    "print(f\"Loaded model trained for {checkpoint['epoch']} epochs\")\n",
    "print(f\"Validation R²: {checkpoint['val_r2']:.4f}\")\n",
    "\n",
    "# Make predictions on validation data as example\n",
    "val_data = data_config['val_data']\n",
    "predictions, model_outputs = model.predict(\n",
    "    val_data['molecular'].cpu().numpy(),\n",
    "    val_data['composition'].cpu().numpy(),\n",
    "    val_data['property'].cpu().numpy()\n",
    ")\n",
    "\n",
    "targets = val_data['targets'].cpu().numpy()\n",
    "\n",
    "print(f\"\\nPrediction Results:\")\n",
    "print(f\"  Mean target: {np.mean(targets):.2f}\")\n",
    "print(f\"  Mean prediction: {np.mean(predictions):.2f}\")\n",
    "print(f\"  Prediction std: {np.std(predictions):.2f}\")\n",
    "\n",
    "# Plot predictions vs targets\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.scatter(targets, predictions, alpha=0.6, s=60)\n",
    "plt.plot([targets.min(), targets.max()], [targets.min(), targets.max()], 'r--', lw=2)\n",
    "plt.xlabel('True Values', fontsize=12)\n",
    "plt.ylabel('Predicted Values', fontsize=12)\n",
    "plt.title(f'Predictions vs True Values (R² = {checkpoint[\"val_r2\"]:.3f})', fontsize=14)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()\n",
    "\n",
    "# Show uncertainty if available\n",
    "if 'uncertainty' in model_outputs:\n",
    "    uncertainties = model_outputs['uncertainty'].cpu().numpy()\n",
    "    \n",
    "    plt.figure(figsize=(12, 5))\n",
    "    \n",
    "    plt.subplot(1, 2, 1)\n",
    "    plt.scatter(predictions, uncertainties, alpha=0.6, s=40)\n",
    "    plt.xlabel('Predicted Values')\n",
    "    plt.ylabel('Uncertainty')\n",
    "    plt.title('Prediction vs Uncertainty')\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.subplot(1, 2, 2)\n",
    "    plt.hist(uncertainties, bins=20, alpha=0.7, edgecolor='black')\n",
    "    plt.xlabel('Uncertainty')\n",
    "    plt.ylabel('Frequency')\n",
    "    plt.title('Uncertainty Distribution')\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    print(f\"\\nUncertainty Analysis:\")\n",
    "    print(f\"  Mean uncertainty: {np.mean(uncertainties):.3f}\")\n",
    "    print(f\"  High confidence samples (unc < 0.1): {np.sum(uncertainties < 0.1)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Feature Importance Analysis"
   ]
  },
